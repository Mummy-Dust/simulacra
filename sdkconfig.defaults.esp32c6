# Splinter v2: extended advertising for genuinely-concurrent decoy instances on the C6.
# With NimBLE as the host, the controller's BT_LE_* ext-adv symbols are inactive
# (they depend on !BT_NIMBLE_ENABLED). The controller derives its concurrent
# instance count from the NimBLE host value below (verified: 4 instances run).
CONFIG_BT_NIMBLE_EXT_ADV=y
CONFIG_BT_NIMBLE_MAX_EXT_ADV_INSTANCES=4

# M5 observe mode: enable the NimBLE observer (scanning) role so ble_gap_disc() can
# passively scan the ambient BLE environment. The default decoy build is broadcaster-only
# and never scans; enabling observer here is inert for it (just links scan support in).
CONFIG_BT_NIMBLE_ROLE_OBSERVER=y

# M8: software coexistence so the Wi-Fi and BT controllers run concurrently and
# esp_coex arbitrates radio access. Our Wi-Fi use is injection-only (no AP association).
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y

# M8: BLE + Wi-Fi together (~1.2 MB binary) exceeds the default 1 MB factory partition.
# Switch to the 1500 K "large" single-app layout, which still fits in 2 MB flash.
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y
